GOOGLE_MAPS_API_KEY=your_streetview_static_api_key
GEMINI_API_KEY=your_gemini_api_key
# Override the model if needed (e.g. fall back to gemini-2.5-flash if 3-flash hits limits)
GEMINI_MODEL=gemini-3-flash-preview

# Bounding box for Davis (slightly padded around city limits)
DAVIS_BBOX_NORTH=38.580
DAVIS_BBOX_SOUTH=38.520
DAVIS_BBOX_EAST=-121.690
DAVIS_BBOX_WEST=-121.790

# Sampling distance along edges (meters)
SAMPLE_INTERVAL_M=80
# Search radius for Street View Metadata (meters). 100 captures greenbelt paths
# whose nearest pano is on a parallel road; lower it (50) for tighter accuracy.
STREETVIEW_RADIUS_M=100

# Routing safety weight (higher = prefer safer, slower routes)
SAFETY_LAMBDA=0.5
# Penalty (in meters of "felt distance") for entering a 1/10 intersection
INTERSECTION_PENALTY_M=60.0

# Storage
DB_PATH=./data/safebike.db
IMAGE_CACHE_DIR=./data/images
